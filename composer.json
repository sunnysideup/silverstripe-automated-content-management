{
    "name": "sunnysideup/automated-content-management",
    "description": "Use AI / LLM (like chatGPT) to manage your content.",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "chatgpt",
        "chat gpt",
        "openai",
        "open ai",
        "lama",
        "llama",
        "claude",
        "ai",
        "llm",
        "content management",
        "cms",
        "content editor",
        "automation",
        "automated"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^6.0",
        "silverstripe/admin": "^3.0",
        "openai-php/client": "^0.15",
        "mozex/anthropic-php": "^1.1",
        "sunnysideup/yes-no-any-filter": "^5.0"
    },
    "suggest": {
        "khalsa-jio/silverstripe-ai-nexus": "The Silverstripe way to connect to LLMs"
    },
    "require-dev": {
        "sunnysideup/sswebpack_engine_only": "^5.0-dev",
        "silverleague/ideannotator": "*",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "silverstripe/standards": "^1",
        "phpstan/extension-installer": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Sunnysideup\\AutomatedContentManagement\\": "src/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [],
    "authors": [
        {
            "name": "Nicolaas Thiemen Francken",
            "email": "modules@sunnysideup.co.nz",
            "role": "lead developer"
        }
    ],
    "yet-to-update": {
        "sunnysideup/classes-and-fields-info": {
            "section": "require",
            "current": "^5.0-dev",
            "reason": "no-compatible-stable-release"
        },
        "sunnysideup/selections": {
            "section": "require",
            "current": "^5.0-dev",
            "reason": "no-compatible-stable-release"
        },
        "sunnysideup/add-casted-variables": {
            "section": "require",
            "current": "^5.0-dev",
            "reason": "no-compatible-stable-release"
        },
        "sunnysideup/optionsetfield-grouped": {
            "section": "require",
            "current": "^5.0-dev",
            "reason": "no-compatible-stable-release"
        }
    }
}
